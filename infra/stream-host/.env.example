# Copy to .env on the streaming host. .env is gitignored — never commit it.
#
#   cp .env.example .env && nano .env

# ── SECRET — you supply this ──────────────────────────────────────────────────
# YouTube Studio -> Go Live -> Stream key. This is a credential: it grants
# anyone who holds it the ability to broadcast to your channel. Never commit it,
# never paste it into a chat, never put it in a script.
YOUTUBE_KEY=

# ── The page to capture ───────────────────────────────────────────────────────
# BOTH query params are mandatory. chromium.sh refuses to start without either.
#
# yt=0    — without it the page renders a design overlay of YouTube's own chrome
#           on top of itself and you would broadcast a mockup of YouTube inside
#           YouTube.
#
# live=1  — marks THIS render as the broadcast, which makes it ignore Stream HQ's
#           mute toggle. Without it the VM's browser is just another window that
#           obeys the toggle, so muting the noise on your own desk would silence
#           the actual YouTube stream. Note the watchdog CANNOT catch this: the
#           heartbeat's audio field reports whether AudioContext is running, not
#           whether the page is muted, so a muted broadcast still beats audio=on.
#           The guard in chromium.sh is the only thing standing in front of it.
STREAM_URL=https://theblob-nkddjp3dmletah2xaeddcs.streamlit.app/?page=Stream&yt=0&live=1

# ── Display ───────────────────────────────────────────────────────────────────
DISPLAY_NUM=:99

# ── Supabase (publishable/anon key — already public in the repo) ──────────────
# The host never needs the DB password. This key only writes stream_health.
SUPA_URL=https://seeevuklabvhkawawtxn.supabase.co
SUPA_KEY=sb_publishable_UFnDfeRb3XFs2UuT0LPPIg_B7K98OeY

# ── Paths ─────────────────────────────────────────────────────────────────────
MUSIC_DIR=/opt/blob-stream/music
FFMPEG_PROGRESS=/run/blob-stream/progress
CHROME_PROFILE=/run/blob-stream/chrome

# ── Tuning ────────────────────────────────────────────────────────────────────
AGENT_INTERVAL=30
WATCHDOG_POLL=20
# The page beats every 15s; 75 tolerates dropped requests without calling a
# healthy render dead.
WATCHDOG_STALE=75
WATCHDOG_GRACE=90
CHROMIUM_UNIT=blob-chromium.service
